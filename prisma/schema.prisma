// Comprobantes (Facturas, Recibos, etc.)
model Comprobante {
  id     String   @id @default(cuid())
  tipo   String
  numero String
  fecha  DateTime

  // Proveedor/Cliente
  razonSocial String
  rut         String?
  direccion   String?

  // Montos
  moneda   String @default("USD")
  subtotal Float
  iva      Float  @default(0)
  total    Float

  // Items del comprobante
  items ItemComprobante[]

  // Archivo
  archivoUrl    String?
  archivoNombre String?

  // OCR
  procesadoOCR Boolean @default(false)
  datosOCR     String?
  confianzaOCR Float?

  // Relación con transacción
  transaccionId String?      @unique
  transaccion   Transaccion? @relation(fields: [transaccionId], references: [id], onDelete: SetNull)

  // Asignación de costos
  asignacionCostos AsignacionCosto[]

  // Relación con cuenta por pagar (AGREGAR ESTA LÍNEA) ⬇️
  cuentaPorPagar CuentaPorPagar?

  // Estado
  estado    String    @default("Pendiente")
  fechaPago DateTime?

  observaciones String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([fecha])
  @@index([estado])
  @@index([tipo])
}

