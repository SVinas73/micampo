  codigo String @unique
  nombre String
  tipo   String // Maquinaria, Instalacion, Vehiculo, Herramienta

  // Datos del activo
  descripcion     String?
  marca           String?
  modelo          String?
  anioFabricacion Int?
  numeroSerie     String?

  // Valuación
  valorAdquisicion Float // USD
  moneda           String   @default("USD")
  fechaAdquisicion DateTime

  // Depreciación
  vidaUtilAnios      Int // Años de vida útil
  valorResidual      Float  @default(0) // Valor al final de la vida útil
  metodoDepreciacion String @default("Lineal") // Lineal, Acelerado

  // Cálculos automáticos
  depreciacionAnual     Float // Calculado
  depreciacionMensual   Float // Calculado
  depreciacionAcumulada Float @default(0)
  valorActual           Float // Valor - Depreciación acumulada

  // Estado
  estado     String    @default("Activo") // Activo, Vendido, Dado de Baja
  fechaBaja  DateTime?
  motivoBaja String?

  // Relación con maquinaria (si aplica)
  maquinariaId String?     @unique
  maquinaria   Maquinaria? @relation(fields: [maquinariaId], references: [id], onDelete: SetNull)

  // Historial de depreciación
  registrosDepreciacion RegistroDepreciacion[]

  observaciones String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([estado])
  @@index([tipo])
}

// Registro de Depreciación Mensual
model RegistroDepreciacion {
  id           String     @id @default(cuid())
  activoFijoId String
  activoFijo   ActivoFijo @relation(fields: [activoFijoId], references: [id], onDelete: Cascade)

  periodo String // YYYY-MM
  mes     Int
  anio    Int

  montoDepreciacion     Float
  depreciacionAcumulada Float
  valorLibros           Float // Valor en libros al final del período

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([activoFijoId, periodo])
  @@index([userId])
  @@index([activoFijoId])
  @@index([periodo])
}

// Tipos de Cambio (Multi-Moneda)
model TipoCambio {
  id    String   @id @default(cuid())
  fecha DateTime @default(now())

  // Monedas
  monedaBase    String @default("USD")
  monedaDestino String // UYU, ARS, BRL

  // Tasas
  compra   Float
  venta    Float
  promedio Float

  // Fuente
  fuente String @default("Manual") // Manual, API, BancoCentral

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([fecha, monedaBase, monedaDestino, userId])
  @@index([userId])
  @@index([fecha])
  @@index([monedaDestino])
}

// Facturas Emitidas (Ventas)
model FacturaEmitida {
  id     String  @id @default(cuid())
  numero String  @unique
  serie  String? // A, B, C
  tipo   String  @default("Factura") // Factura, NotaCredito, NotaDebito

  fecha            DateTime
  fechaVencimiento DateTime?

  // Cliente
  clienteNombre    String
  clienteRut       String?
  clienteDireccion String?
  clienteEmail     String?

  // Montos
  moneda   String @default("USD")
  subtotal Float
  iva      Float
  total    Float

  // Items
  items ItemFacturaEmitida[]

  // Cobro
  estadoCobro  String @default("Pendiente") // Pendiente, Parcial, Cobrado
  montoCobrado Float  @default(0)
  saldo        Float // Total - MontoCobrado

  // Pagos recibidos
  pagos PagoRecibido[]

  observaciones String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([fecha])
  @@index([estadoCobro])
}

// Items de Facturas Emitidas
model ItemFacturaEmitida {
  id        String         @id @default(cuid())
  facturaId String
  factura   FacturaEmitida @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  descripcion    String
  cantidad       Float
  precioUnitario Float
  subtotal       Float
  iva            Float
  total          Float

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([facturaId])
}

// Pagos Recibidos
model PagoRecibido {
  id        String         @id @default(cuid())
  facturaId String
  factura   FacturaEmitida @relation(fields: [facturaId], references: [id], onDelete: Cascade)

  fecha  DateTime
  monto  Float
  moneda String   @default("USD")

  metodoPago String // Efectivo, Transferencia, Cheque, Tarjeta
  referencia String? // Número de transferencia, cheque, etc

  observaciones String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([facturaId])
  @@index([fecha])
}

// Cuentas por Pagar
model CuentaPorPagar {
  id            String       @id @default(cuid())
  comprobanteId String?      @unique
  comprobante   Comprobante? @relation(fields: [comprobanteId], references: [id], onDelete: SetNull)

  // Proveedor
  proveedor    String
  proveedorRut String?

  // Deuda
  concepto         String
  fechaEmision     DateTime
  fechaVencimiento DateTime
  monto            Float
  moneda           String   @default("USD")

  // Pagos
  estadoPago  String @default("Pendiente") // Pendiente, Parcial, Pagado
  montoPagado Float  @default(0)
  saldo       Float // Monto - MontoPagado

  pagos PagoRealizado[]

  observaciones String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([estadoPago])
  @@index([fechaVencimiento])
}

// Pagos Realizados
model PagoRealizado {
  id               String         @id @default(cuid())
  cuentaPorPagarId String
  cuentaPorPagar   CuentaPorPagar @relation(fields: [cuentaPorPagarId], references: [id], onDelete: Cascade)

  fecha  DateTime
  monto  Float
  moneda String   @default("USD")

  metodoPago String // Efectivo, Transferencia, Cheque
  referencia String?

  cuentaBancariaId String?
  cuentaBancaria   CuentaBancaria? @relation(fields: [cuentaBancariaId], references: [id], onDelete: SetNull)

  observaciones String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([cuentaPorPagarId])
  @@index([fecha])
}

// Empleados
model Empleado {
  id     String @id @default(cuid())
  legajo String @unique

  // Datos personales
  nombre          String
  apellido        String
  documento       String
  fechaNacimiento DateTime?
  email           String?
  telefono        String?
  direccion       String?

  // Laborales
  cargo        String
  area         String? // Agricultura, Ganadería, Administración, Mantenimiento
  fechaIngreso DateTime
  fechaEgreso  DateTime?
  estado       String    @default("Activo") // Activo, Inactivo, Despedido

  // Remuneración
  tipoContrato String // Mensual, Jornal, Por Hora
  salarioBase  Float // En moneda base
  moneda       String @default("USD")

  // Beneficios
  aguinaldo         Boolean @default(true)
  salarioVacacional Boolean @default(true)

  // Relaciones
  registrosHoras RegistroHorasEmpleado[]
  pagos          PagoSalario[]
  tareas         TareaEmpleado[]

  observaciones String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([estado])
  @@index([area])
}

// Registro de Horas de Empleados
model RegistroHorasEmpleado {
  id         String   @id @default(cuid())
  empleadoId String
  empleado   Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  fecha          DateTime
  horasRegulares Float    @default(0)
  horasExtra     Float    @default(0)
  horasNocturnas Float    @default(0)

  // Actividad
  actividad     String? // Siembra, Cosecha, Mantenimiento, etc
  loteId        String?
  observaciones String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([empleadoId])
  @@index([fecha])
}

// Pagos de Salario
model PagoSalario {
  id         String   @id @default(cuid())
  empleadoId String
  empleado   Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  periodo   String // YYYY-MM
  fechaPago DateTime

  // Conceptos
  salarioBase    Float
  horasExtra     Float @default(0)
  bonificaciones Float @default(0)
  deducciones    Float @default(0)

  // Total
  totalBruto Float
  totalNeto  Float

  moneda     String @default("USD")
  metodoPago String @default("Transferencia")

  observaciones String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([empleadoId, periodo])
  @@index([userId])
  @@index([empleadoId])
  @@index([periodo])
}

// Tareas Asignadas a Empleados
model TareaEmpleado {
  id         String   @id @default(cuid())
  empleadoId String
  empleado   Empleado @relation(fields: [empleadoId], references: [id], onDelete: Cascade)

  titulo      String
  descripcion String?
  prioridad   String  @default("Media") // Baja, Media, Alta, Urgente

  fechaAsignacion  DateTime  @default(now())
  fechaVencimiento DateTime?
  fechaCompletada  DateTime?

  estado String @default("Pendiente") // Pendiente, EnProceso, Completada, Cancelada

  // Ubicación
  loteId    String?
  ubicacion String?

  observaciones String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([empleadoId])
  @@index([estado])
  @@index([fechaVencimiento])
}

// Roles y Permisos
model Rol {
  id          String  @id @default(cuid())
  nombre      String // Admin, Gerente, Agronomo, Inversor, Contratista
  descripcion String?

  // Permisos por módulo (JSON)
  permisos String // JSON: {finanzas: {ver: true, editar: false}, ganaderia: {...}}

  // Usuarios con este rol
  usuariosRol UsuarioRol[]

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, nombre])
  @@index([userId])
}

// Relación Usuario-Rol
model UsuarioRol {
  id           String @id @default(cuid())
  usuarioEmail String // Email del usuario invitado
  rolId        String
  rol          Rol    @relation(fields: [rolId], references: [id], onDelete: Cascade)

  estado          String    @default("Activo") // Activo, Inactivo, Invitado
  fechaInvitacion DateTime  @default(now())
  fechaAceptacion DateTime?

  // Restricciones adicionales
  restricciones String? // JSON con restricciones específicas

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([usuarioEmail, rolId, userId])
  @@index([userId])
  @@index([usuarioEmail])
}

// Portal de Contratistas
model Contratista {
  id       String  @id @default(cuid())
  nombre   String
  empresa  String?
  rut      String?
  email    String  @unique
  telefono String?

  // Especialidad
  especialidad String // Siembra, Cosecha, Pulverizacion, Transporte

  // Acceso
  codigoAcceso String @unique
  estado       String @default("Activo") // Activo, Inactivo, Bloqueado

  // Trabajos asignados
  trabajos TrabajoContratista[]

  observaciones String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([email])
  @@index([estado])
}

// Trabajos Asignados a Contratistas
model TrabajoContratista {
  id            String      @id @default(cuid())
  contratistaId String
  contratista   Contratista @relation(fields: [contratistaId], references: [id], onDelete: Cascade)

  titulo      String
  descripcion String
  tipo        String // Siembra, Cosecha, Pulverizacion, etc

  // Ubicación
  loteId     String?
  loteNombre String?
  hectareas  Float?

  // Fechas
  fechaAsignacion DateTime  @default(now())
  fechaInicio     DateTime?
  fechaCompletada DateTime?

  // Estado
  estado String @default("Asignado") // Asignado, EnProceso, Completado, Cancelado

  // Archivos subidos por contratista
  archivosUrl String? // JSON con URLs

  // Pago
  monto      Float?
  moneda     String @default("USD")
  estadoPago String @default("Pendiente") // Pendiente, Pagado

  observaciones String?

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([contratistaId])
  @@index([estado])
}

// ============================================
// MODELOS BASE NECESARIOS PARA MAQUINARIA
// ============================================

model Establecimiento {
  id               String  @id @default(cuid())
  nombre           String
  direccion        String?
  ciudad           String?
  provincia        String?
  pais             String  @default("Uruguay")
  hectareasTotales Float?

  // Límite geográfico del establecimiento (dibujado en el mapa)
  coordenadas    String? // GeoJSON Polygon del contorno
  centroLatitud  Float?
  centroLongitud Float?
  perimetro      Float? // metros

  // ⬇️ AGREGAR ESTAS LÍNEAS
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  cuit String? // ⬅️ AGREGAR

  // Relaciones
  maquinarias Maquinaria[]
  lotes       Lote[]

  // NUEVAS RELACIONES SOSTENIBILIDAD:
  huellasCarbono       HuellaCarbono[]
  recetasAgronomicas   RecetaAgronomica[]
  reportesAgroquimicos ReporteAgroquimico[]
  certificaciones      CertificacionSostenibilidad[]
  declaracionesEUDR    ComplianceEUDR[]
  marcadoresGeo        MarcadorGeorreferenciado[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([nombre])
  @@index([userId]) // ⬅️ AGREGAR ÍNDICE
}

model RegistroCombustible {
  id           String     @id @default(cuid())
  maquinariaId String
  maquinaria   Maquinaria @relation(fields: [maquinariaId], references: [id], onDelete: Cascade)

  fecha         DateTime @default(now())
  litros        Float
  costoLitro    Float
  costoTotal    Float
  horasMotor    Float?
  operador      String?
  estacion      String?
  observaciones String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([maquinariaId])
  @@index([fecha])
}

model UsoMaquinaria {
  id           String     @id @default(cuid())
  maquinariaId String
  maquinaria   Maquinaria @relation(fields: [maquinariaId], references: [id], onDelete: Cascade)

  fecha           DateTime @default(now())
  operador        String
  horasInicio     Float
  horasFin        Float
  horasTrabajadas Float
  tarea           String // "Siembra", "Pulverización", "Cosecha", etc
  loteId          String?
  loteNombre      String?
  observaciones   String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([maquinariaId])
  @@index([fecha])
  @@index([operador])
}

model Mantenimiento {
  id           String     @id @default(cuid())
  maquinariaId String
  maquinaria   Maquinaria @relation(fields: [maquinariaId], references: [id], onDelete: Cascade)

  tipo          String // "Preventivo", "Correctivo", "Predictivo"
  descripcion   String
  fecha         DateTime @default(now())
  horasMotor    Float?
  costo         Float?
  observaciones String?
  estado        String   @default("Pendiente") // "Pendiente", "En Proceso", "Completado"

  // NUEVO: Relación con orden de taller
  ordenTallerId String? // Si el mantenimiento generó una orden

  repuestos UsoRepuesto[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  User      User?    @relation(fields: [userId], references: [id])
  userId    String?

  @@index([maquinariaId])
  @@index([estado])
  @@index([tipo])
}

model Maquinaria {
  id              String  @id @default(cuid())
  codigo          String  @unique
  tipo            String // "Tractor", "Cosechadora", "Pulverizadora", "Sembradora", "Tolva"
  marca           String
  modelo          String
  numeroSerie     String? @unique
  anioFabricacion Int?
  patente         String? @unique
  horasMotor      Float   @default(0)
  estado          String  @default("Operativo") // "Operativo", "Mantenimiento", "Averiado", "Fuera de Servicio"

  // Información adicional
  capacidad        String? // "180 HP", "500 litros", etc
  valorAdquisicion Float?
  fechaAdquisicion DateTime?

  // Configuración de mantenimiento
  intervaloMantenimiento Float? @default(250) // Cada cuántas horas
  ultimoMantenimiento    Float? @default(0) // Horas del último servicio

  // Relaciones existentes
  establecimientoId String
  establecimiento   Establecimiento @relation(fields: [establecimientoId], references: [id], onDelete: Cascade)

  mantenimientos       Mantenimiento[]
  registrosCombustible RegistroCombustible[]
  usosMaquinaria       UsoMaquinaria[]

  // NUEVAS RELACIONES
  posicionesGPS        TelemetriaGPS[]
  eficiencia           EficienciaMaquinaria[]
  alertas              AlertaMantenimiento[]
  sensores             SensorPredictivo[]
  ordenesTaller        OrdenTaller[]
  evaluacionesOperador EvaluacionOperador[]

  // ✅ AGREGAR ESTAS 3 RELACIONES FALTANTES:
  labores           Labor[] // ← AGREGAR
  cargasCombustible CargaCombustible[] // ← AGREGAR
  activoFijo        ActivoFijo? // ← AGREGAR (relación 1-1)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([establecimientoId])
  @@index([estado])
  @@index([tipo])
}

// ============================================
// 1. TELEMÁTICA GPS
// ============================================

model TelemetriaGPS {
  id           String     @id @default(cuid())
  maquinariaId String
  maquinaria   Maquinaria @relation(fields: [maquinariaId], references: [id], onDelete: Cascade)

  // Coordenadas
  latitud  Float
  longitud Float

  // Datos de movimiento
  velocidad Float? @default(0) // km/h
  rumbo     Float? @default(0) // grados (0-360)
  altitud   Float? // metros
  precision Float? // metros

  // Estado de la máquina
  estadoMotor      String? @default("Apagado") // "Encendido", "Apagado", "Ralenti"
  horasMotor       Float?
  nivelCombustible Float? // Porcentaje

  // Metadata
  timestamp DateTime @default(now())
  createdAt DateTime @default(now())

  @@index([maquinariaId])
  @@index([timestamp])
}

// ============================================
// 2. EFICIENCIA DE USO
// ============================================

model EficienciaMaquinaria {
  id           String     @id @default(cuid())
  maquinariaId String
  maquinaria   Maquinaria @relation(fields: [maquinariaId], references: [id], onDelete: Cascade)

  fecha DateTime @default(now())

  // Tiempos
  horasTrabajando Float @default(0) // Tiempo real de trabajo productivo
  horasRalenti    Float @default(0) // Tiempo en marcha mínima
  horasApagado    Float @default(0) // Tiempo apagado durante jornada
  horasTotales    Float @default(0) // Total de horas registradas

  // Consumo
  consumoCombustible Float? @default(0) // Litros
  consumoPorHora     Float? @default(0) // Litros/hora

  // Distancia y área
  distanciaRecorrida Float? @default(0) // Kilómetros
  areaTrabajadasHa   Float? @default(0) // Hectáreas trabajadas

  // Scores calculados
  eficienciaScore    Float? @default(0) // 0-100 (% tiempo trabajando / tiempo total)
  consumoScore       Float? @default(0) // 0-100 (comparado con ideal)
  productividadScore Float? @default(0) // 0-100 (ha/hora vs ideal)
  scoreGeneral       Float? @default(0) // 0-100 (promedio ponderado)

  // Contexto
  operador String?
  loteId   String?
  tarea    String?

  createdAt DateTime @default(now())

  @@index([maquinariaId])
  @@index([fecha])
  @@index([operador])
}

// ============================================
// 3. ALERTAS DE MANTENIMIENTO
// ============================================

model AlertaMantenimiento {
  id           String     @id @default(cuid())
  maquinariaId String
  maquinaria   Maquinaria @relation(fields: [maquinariaId], references: [id], onDelete: Cascade)

  tipo      String // "HorasMotor", "FechaVencimiento", "Predictivo", "Manual"
  categoria String // "Aceite", "Filtros", "Correas", "Neumáticos", "Hidráulico", "Otro"
  prioridad String // "Crítica", "Alta", "Media", "Baja"

  titulo      String
  descripcion String

  // Triggers
  horasMotorAlerta Float? // Horas en las que debe saltar
  fechaAlerta      DateTime? // Fecha en la que debe saltar
  sensorAlerta     Boolean?  @default(false) // Viene de sensor predictivo

  // Estado
  estado          String    @default("Activa") // "Activa", "Atendida", "Pospuesta", "Cancelada"
  fechaCreacion   DateTime  @default(now())
  fechaResolucion DateTime?
  resueltoPor     String?
  observaciones   String?

  // Relación con orden de taller
  ordenTallerId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([maquinariaId])
  @@index([estado])
  @@index([prioridad])
  @@index([tipo])
}

// ============================================
// 4. SENSORES PREDICTIVOS
// ============================================

model SensorPredictivo {
  id           String     @id @default(cuid())
  maquinariaId String
  maquinaria   Maquinaria @relation(fields: [maquinariaId], references: [id], onDelete: Cascade)

  // Identificación del sensor
  codigoSensor String // "TEMP-MOT-01", "VIB-TRANS-01"
  tipoSensor   String // "Temperatura", "Vibración", "Presión", "Aceite"
  ubicacion    String // "Motor", "Transmisión", "Hidráulico", "Frenos"

  // Valores
  valorActual   Float
  valorMinimo   Float // Valor mínimo normal
  valorMaximo   Float // Valor máximo normal
  umbralAlerta  Float // Cuándo alertar
  umbralCritico Float // Cuándo es crítico
  unidad        String // "°C", "Hz", "PSI", "ppm"

  // Estado
  estado        String   @default("Normal") // "Normal", "Alerta", "Crítico"
  ultimaLectura DateTime @default(now())

  // Historial
  lecturas LecturaSensor[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([maquinariaId, codigoSensor])
  @@index([maquinariaId])
  @@index([estado])
  @@index([tipoSensor])
}

// Lecturas históricas de sensores
model LecturaSensor {
  id       String           @id @default(cuid())
  sensorId String
  sensor   SensorPredictivo @relation(fields: [sensorId], references: [id], onDelete: Cascade)

  valor       Float
  estado      String // "Normal", "Alerta", "Crítico"
  timestamp   DateTime   @default(now())
  User        User?      @relation(fields: [userId], references: [id])
  userId      String?
  SensorIoT   SensorIoT? @relation(fields: [sensorIoTId], references: [id])
  sensorIoTId String?

  @@index([sensorId])
  @@index([timestamp])
}

// ============================================
// 5. ÓRDENES DE TALLER
// ============================================

model OrdenTaller {
  id           String     @id @default(cuid())
  numeroOrden  String     @unique // "OT-2024-001"
  maquinariaId String
  maquinaria   Maquinaria @relation(fields: [maquinariaId], references: [id], onDelete: Cascade)

  // Clasificación
  tipo      String // "Reparación", "Mantenimiento", "Inspección", "Modificación"
  categoria String // "Motor", "Transmisión", "Hidráulico", "Eléctrico", "Chapa", "Otro"
  prioridad String // "Urgente", "Alta", "Media", "Baja"

  // Descripción del trabajo
  descripcionFalla String  @db.Text
  diagnostico      String? @db.Text
  trabajoRealizado String? @db.Text

  // Fechas
  fechaIngreso  DateTime  @default(now())
  fechaEstimada DateTime?
  fechaInicio   DateTime?
  fechaSalida   DateTime?

  // Asignación
  mecanicoAsignado String?
  ayudantes        String[] // Array de nombres

  // Estado
  estado            String @default("Ingresada") // "Ingresada", "Diagnosticando", "En Proceso", "Esperando Repuestos", "Completada", "Cancelada"
  horasMotorIngreso Float?

  // Repuestos y mano de obra
  repuestos RepuestoUsado[]
  manoObra  ManoObraTaller[]

