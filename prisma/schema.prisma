generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Usuario
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  password      String
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  campos        Campo[]
  transacciones Transaccion[]
  lotes         Lote[]        
  siembras      Siembra[]     
  cosechas      Cosecha[]
  animales          Animal[]           
  eventosSanitarios EventoSanitario[]  
  registrosPeso     RegistroPeso[]     
  movimientos       Movimiento[]       
  maquinas          Maquina[]          
  mantenimientos    Mantenimiento[]    
  registrosHoras    RegistroHoras[]
  contratos           Contrato[]          // ← NUEVO
  entregas            Entrega[]           // ← NUEVO
  preciosReferencia   PrecioReferencia[]  // ← NUEVO
  emisionesCarbono      EmisionCarbono[]      // ← NUEVO
  practicasSostenibles  PracticaSostenible[]  // ← NUEVO
  certificaciones       Certificacion[]       // ← NUEVO
  labores               Labor[]                  // ← NUEVO
  aplicacionesProductos AplicacionProducto[]     // ← NUEVO
  eventosReproductivos    EventoReproductivo[]      // ← NUEVO
  historialesReproductivos HistorialReproductivo[]  // ← NUEVO
  productos               Producto[]                  // ← NUEVO
  ubicacionesProducto     UbicacionProducto[]         // ← NUEVO
  transferenciasProducto  TransferenciaProducto[]     // ← NUEVO
  alertasClimaticas       AlertaClimatica[]         // ← NUEVO
  ubicaciones             Ubicacion[]               // ← NUEVO
  alimentos               Alimento[]                // ← NUEVO
  raciones                Racion[]                  // ← NUEVO
  componentesRacion       ComponenteRacion[]        // ← NUEVO
  cuentasBancarias        CuentaBancaria[]          // ← NUEVO
  extractosBancarios      ExtractoBancario[]        // ← NUEVO
  conciliaciones          Conciliacion[]            // ← NUEVO
  diferenciasConciliacion DiferenciaConciliacion[]  // ← NUEVO
  registrosLecheros       RegistroLechero[]        // ← NUEVO
  costosLote              CostoLote[]              // ← NUEVO
  costosAnimal            CostoAnimal[]            // ← NUEVO
  margenesBrutos          MargenBruto[]            // ← NUEVO
  arrendamientos          Arrendamiento[]          // ← NUEVO         
  
  @@map("users")
}

// Campo/Establecimiento
model Campo {
  id         String   @id @default(cuid())
  nombre     String
  hectareas  Decimal? @db.Decimal(10, 2)
  ubicacion  String?
  userId     String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  transacciones Transaccion[]

  @@map("campos")
}

// Transacción Financiera
model Transaccion {
  id          String   @id @default(cuid())
  tipo        String   // 'ingreso' o 'gasto'
  categoria   String
  monto       Decimal  @db.Decimal(12, 2)
  descripcion String?
  fecha       DateTime
  userId      String
  campoId     String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  extractoBancario ExtractoBancario?  // ← NUEVO

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  campo Campo? @relation(fields: [campoId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([fecha])
  @@index([tipo])
  @@map("transacciones")
}

model Lote {
  id          String   @id @default(cuid())
  nombre      String
  hectareas   Float
  cultivo     String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  siembras    Siembra[]
  cosechas    Cosecha[]
  emisionesCarbono EmisionCarbono[]     // ← NUEVO
  practicasSostenibles PracticaSostenible[] // ← NUEVO
  labores     Labor[]
  ubicacionesProducto UbicacionProducto[]  // ← NUEVO
  costos                CostoLote[]
  arrendamientos        Arrendamiento[]          // ← NUEVO
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
}

model Siembra {
  id          String   @id @default(cuid())
  cultivo     String
  variedad    String?
  fechaSiembra DateTime
  hectareas   Float
  loteId      String
  lote        Lote     @relation(fields: [loteId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  cosechas    Cosecha[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([loteId])
}

model Cosecha {
  id             String   @id @default(cuid())
  fechaCosecha   DateTime
  rendimiento    Float    // kg/ha
  calidad        String?
  precioVenta    Float?
  siembraId      String
  siembra        Siembra  @relation(fields: [siembraId], references: [id], onDelete: Cascade)
  loteId         String
  lote           Lote     @relation(fields: [loteId], references: [id], onDelete: Cascade)
  userId         String
  user           User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([userId])
  @@index([siembraId])
  @@index([loteId])
}

model Animal {
  id              String   @id @default(cuid())
  caravana        String   // Identificador único
  tipo            String   // Vacuno, Ovino, etc
  raza            String?
  sexo            String   // Macho, Hembra
  fechaNacimiento DateTime?
  pesoNacimiento  Float?
  madre           String?  // Caravana de la madre
  padre           String?  // Caravana del padre
  estado          String   @default("Activo") // Activo, Vendido, Muerto
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventosSanitarios EventoSanitario[]
  registrosPeso   RegistroPeso[]
  movimientos     Movimiento[]
  eventosReproductivos EventoReproductivo[]      // ← NUEVO
  historialReproductivo HistorialReproductivo?   // ← NUEVO
  registrosLecheros RegistroLechero[]      // ← NUEVO
  costos                CostoAnimal[]            // ← NUEVO
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([caravana])
}

model EventoSanitario {
  id          String   @id @default(cuid())
  tipo        String   // Vacunación, Desparasitación, Tratamiento
  descripcion String
  fecha       DateTime
  producto    String?
  dosis       String?
  animalId    String
  animal      Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  costos      CostoAnimal[]                    // ← NUEVO
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([animalId])
}

model RegistroPeso {
  id        String   @id @default(cuid())
  fecha     DateTime
  peso      Float    // kg
  animalId  String
  animal    Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([animalId])
}

model Movimiento {
  id          String   @id @default(cuid())
  tipo        String   // Compra, Venta, Nacimiento, Muerte
  fecha       DateTime
  descripcion String?
  monto       Float?   // Para compras/ventas
  animalId    String
  animal      Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([animalId])
}

model Maquina {
  id              String   @id @default(cuid())
  nombre          String
  tipo            String   // Tractor, Cosechadora, Sembradora, etc
  marca           String?
  modelo          String?
  anio            Int?
  horasActuales   Float    @default(0)
  estado          String   @default("Operativa") // Operativa, En Mantenimiento, Fuera de Servicio
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  mantenimientos  Mantenimiento[]
  registrosHoras  RegistroHoras[]
  labores         Labor[]
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model Mantenimiento {
  id          String   @id @default(cuid())
  tipo        String   // Preventivo, Correctivo
  descripcion String
  fecha       DateTime
  costo       Float?
  horasActuales Float?
  maquinaId   String
  maquina     Maquina  @relation(fields: [maquinaId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([maquinaId])
}

model RegistroHoras {
  id          String   @id @default(cuid())
  fecha       DateTime
  horasInicio Float
  horasFin    Float
  actividad   String?  // Siembra, Cosecha, Pulverización, etc
  maquinaId   String
  maquina     Maquina  @relation(fields: [maquinaId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([maquinaId])
}


model Contrato {
  id            String   @id @default(cuid())
  tipo          String   // Compra, Venta
  producto      String   // Soja, Maíz, Trigo, etc
  cantidad      Float    // Toneladas
  precioUnitario Float   // USD/ton
  montoTotal    Float    // USD
  comprador     String?  // Nombre comprador/vendedor
  fechaContrato DateTime
  fechaEntrega  DateTime?
  estado        String   @default("Pendiente") // Pendiente, Entregado, Cancelado
  observaciones String?
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  entregas      Entrega[]
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([fechaContrato])
}

model Entrega {
  id          String   @id @default(cuid())
  fecha       DateTime
  cantidad    Float    // Toneladas entregadas
  contratoId  String
  contrato    Contrato @relation(fields: [contratoId], references: [id], onDelete: Cascade)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([contratoId])
}

model PrecioReferencia {
  id        String   @id @default(cuid())
  producto  String   // Soja, Maíz, Trigo
  precio    Float    // USD/ton
  fecha     DateTime
  fuente    String?  // Bolsa de Rosario, Chicago, etc
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([producto])
  @@index([fecha])
}


model EmisionCarbono {
  id          String   @id @default(cuid())
  fuente      String   // Combustible, Fertilizantes, Ganadería, Electricidad
  actividad   String   // Descripción de la actividad
  cantidad    Float    // Cantidad (litros, kg, kWh, cabezas)
  unidad      String   // Litros, kg, kWh, cabezas
  factorEmision Float  // kg CO2eq por unidad
  emisionTotal Float   // kg CO2eq total
  fecha       DateTime
  loteId      String?
  lote        Lote?    @relation(fields: [loteId], references: [id], onDelete: SetNull)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([fecha])
  @@index([fuente])
}

model PracticaSostenible {
  id          String   @id @default(cuid())
  tipo        String   // Rotación cultivos, Siembra directa, Agroforestería, etc
  nombre      String
  descripcion String
  fechaInicio DateTime
  fechaFin    DateTime?
  beneficio   String?  // Reducción estimada de emisiones, mejora suelo, etc
  loteId      String?
  lote        Lote?    @relation(fields: [loteId], references: [id], onDelete: SetNull)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([tipo])
}

model Certificacion {
  id              String   @id @default(cuid())
  nombre          String   // Orgánico, Rainforest Alliance, Fair Trade, etc
  entidadEmisora  String   // Organismo certificador
  numeroRegistro  String?
  fechaEmision    DateTime
  fechaVencimiento DateTime?
  estado          String   @default("Vigente") // Vigente, Vencida, En Proceso
  documentoUrl    String?  // Link al certificado
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([estado])
}

model Labor {
  id              String   @id @default(cuid())
  tipo            String   // Siembra, Cosecha, Pulverización, Fertilización, Labranza, Riego
  fecha           DateTime
  loteId          String
  lote            Lote     @relation(fields: [loteId], references: [id], onDelete: Cascade)
  superficieTrabajada Float // Hectáreas
  descripcion     String
  observaciones   String?
  
  // Personal
  operarios       String?  // Nombres separados por coma
  horasTrabajadas Float?
  
  // Maquinaria
  maquinaId       String?
  maquina         Maquina? @relation(fields: [maquinaId], references: [id], onDelete: SetNull)
  
  // Productos aplicados
  aplicacionesProductos AplicacionProducto[]
  costos                CostoLote[]              // ← NUEVO
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([loteId])
  @@index([fecha])
}

model AplicacionProducto {
  id              String   @id @default(cuid())
  laborId         String
  labor           Labor    @relation(fields: [laborId], references: [id], onDelete: Cascade)
  tipoProducto    String   // Herbicida, Insecticida, Fungicida, Fertilizante
  nombreProducto  String
  principioActivo String?
  dosis           Float    // L/ha o kg/ha
  unidadDosis     String   // L/ha, kg/ha, cc/ha
  metodoAplicacion String? // Terrestre, Aéreo
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([laborId])
}

model EventoReproductivo {
  id              String   @id @default(cuid())
  tipo            String   // Celo, Servicio, Diagnostico, Parto, Destete, Aborto
  fecha           DateTime
  animalId        String
  animal          Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  
  // Específico para Servicio
  tipoServicio    String?  // Natural, IA (Inseminación Artificial)
  toroId          String?  // ID del toro (si es monta natural)
  semenId         String?  // Identificación del semen (si es IA)
  
  // Específico para Diagnóstico
  resultado       String?  // Preñada, Vacía
  diasGestacion   Int?
  
  // Específico para Parto
  numCrias        Int?     // Cantidad de crías nacidas
  condicionParto  String?  // Normal, Asistido, Cesárea
  
  // Crías resultantes del parto
  crias           String?  // IDs de las crías separados por coma
  
  observaciones   String?
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([animalId])
  @@index([fecha])
  @@index([tipo])
}

model HistorialReproductivo {
  id                    String   @id @default(cuid())
  animalId              String   @unique
  animal                Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  
  totalPartos           Int      @default(0)
  totalCriasNacidas     Int      @default(0)
  totalCriasVivas       Int      @default(0)
  ultimoParto           DateTime?
  ultimoServicio        DateTime?
  ultimoDiagnostico     DateTime?
  estadoActual          String   @default("Vacía") // Vacía, Preñada, En Servicio
  fechaEsperadaParto    DateTime?
  
  userId                String
  user                  User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([userId])
  @@index([animalId])
}

model Producto {
  id          String   @id @default(cuid())
  nombre      String
  categoria   String   // Semilla, Fertilizante, Fitosanitario, Repuesto, Otro
  unidad      String   // kg, L, unidades
  stockMinimo Float    @default(0)
  ubicaciones UbicacionProducto[]
  transferencias TransferenciaProducto[]
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([categoria])
}

model UbicacionProducto {
  id          String   @id @default(cuid())
  productoId  String
  producto    Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  ubicacion   String   // Depósito Central, Lote 1, Galpón 2, etc
  loteId      String?
  lote        Lote?    @relation(fields: [loteId], references: [id], onDelete: SetNull)
  cantidad    Float
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([productoId])
  @@index([loteId])
}

model TransferenciaProducto {
  id              String   @id @default(cuid())
  productoId      String
  producto        Producto @relation(fields: [productoId], references: [id], onDelete: Cascade)
  origenUbicacion String
  destinoUbicacion String
  cantidad        Float
  fecha           DateTime
  motivo          String?
  responsable     String?
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([productoId])
  @@index([fecha])
}

model AlertaClimatica {
  id              String   @id @default(cuid())
  tipo            String   // Helada, Lluvia, Viento, Temperatura, Sequía
  severidad       String   // Baja, Media, Alta, Extrema
  titulo          String
  descripcion     String
  fechaInicio     DateTime
  fechaFin        DateTime?
  temperatura     Float?
  precipitacion   Float?
  viento          Float?
  humedad         Float?
  ubicacion       String
  latitud         Float?
  longitud        Float?
  recomendacion   String?
  fuenteDatos     String   @default("OpenMeteo")
  leida           Boolean  @default(false)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([fechaInicio])
  @@index([tipo])
  @@index([leida])
}

model Ubicacion {
  id          String   @id @default(cuid())
  nombre      String   // Ej: "Campo Los Alamos"
  ciudad      String?
  provincia   String?
  pais        String   @default("Uruguay")
  latitud     Float
  longitud    Float
  esPrincipal Boolean  @default(false)
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([esPrincipal])
}


model Alimento {
  id                String   @id @default(cuid())
  nombre            String
  tipo              String   // Forraje, Concentrado, Suplemento, Mineral
  proteina          Float    // Porcentaje de proteína
  energia           Float    // Mcal/kg (Megacalorías por kg)
  fibraCruda        Float?   // Porcentaje
  humedad           Float?   // Porcentaje
  costoKg           Float    // Costo por kg en USD
  disponibilidad    String   @default("Disponible") // Disponible, Agotado
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  raciones          ComponenteRacion[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([tipo])
}

model Racion {
  id                String   @id @default(cuid())
  nombre            String
  animalObjetivo    String   // Vaca lechera, Ternero, Novillo, etc
  pesoObjetivo      Float    // Peso del animal en kg
  etapaProductiva   String   // Crecimiento, Engorde, Lactancia, Gestación, Mantenimiento
  consumoDiario     Float    // kg MS (Materia Seca) por día
  proteinaTotal     Float    // % calculado
  energiaTotal      Float    // Mcal/kg calculado
  costoTotal        Float    // USD por día
  observaciones     String?
  recomendacionIA   String?  // Recomendación generada por IA
  componentes       ComponenteRacion[]
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([animalObjetivo])
}

model ComponenteRacion {
  id              String   @id @default(cuid())
  racionId        String
  racion          Racion   @relation(fields: [racionId], references: [id], onDelete: Cascade)
  alimentoId      String
  alimento        Alimento @relation(fields: [alimentoId], references: [id], onDelete: Cascade)
  cantidad        Float    // kg de materia seca
  porcentaje      Float    // % de la ración total
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([racionId])
  @@index([alimentoId])
}

model CuentaBancaria {
  id              String   @id @default(cuid())
  nombre          String
  banco           String
  numeroCuenta    String
  tipoCuenta      String   // Cuenta Corriente, Caja de Ahorro
  moneda          String   @default("USD")
  saldoActual     Float    @default(0)
  saldoLibros     Float    @default(0)
  activa          Boolean  @default(true)
  extractos       ExtractoBancario[]
  conciliaciones  Conciliacion[]
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
}

model ExtractoBancario {
  id              String   @id @default(cuid())
  cuentaId        String
  cuenta          CuentaBancaria @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
  fecha           DateTime
  descripcion     String
  referencia      String?
  debito          Float?
  credito         Float?
  saldo           Float
  conciliado      Boolean  @default(false)
  transaccionId   String?  @unique
  transaccion     Transaccion? @relation(fields: [transaccionId], references: [id], onDelete: SetNull)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([cuentaId])
  @@index([fecha])
  @@index([conciliado])
}

model Conciliacion {
  id                String   @id @default(cuid())
  cuentaId          String
  cuenta            CuentaBancaria @relation(fields: [cuentaId], references: [id], onDelete: Cascade)
  fechaInicio       DateTime
  fechaFin          DateTime
  saldoInicialBanco Float
  saldoFinalBanco   Float
  saldoInicialLibros Float
  saldoFinalLibros  Float
  diferencia        Float
  estado            String   @default("Pendiente") // Pendiente, Conciliado, Con Diferencias
  itemsConciliados  Int      @default(0)
  itemsPendientes   Int      @default(0)
  observaciones     String?
  diferencias       DiferenciaConciliacion[]
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([cuentaId])
  @@index([fechaInicio])
}

model DiferenciaConciliacion {
  id              String   @id @default(cuid())
  conciliacionId  String
  conciliacion    Conciliacion @relation(fields: [conciliacionId], references: [id], onDelete: Cascade)
  tipo            String   // EnLibrosNoEnBanco, EnBancoNoEnLibros, Diferencia de Monto
  fecha           DateTime
  descripcion     String
  montoLibros     Float?
  montoBanco      Float?
  diferencia      Float
  resuelto        Boolean  @default(false)
  observacion     String?
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([conciliacionId])
}

model RegistroLechero {
  id          String   @id @default(cuid())
  animalId    String
  animal      Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  fecha       DateTime
  litros      Float    // Litros de leche producidos
  turno       String?  // Mañana, Tarde, Noche
  calidad     String?  // A, B, C (según parámetros de grasa/proteína)
  observaciones String?
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([animalId])
  @@index([fecha])
}

model CostoLote {
  id              String   @id @default(cuid())
  loteId          String
  lote            Lote     @relation(fields: [loteId], references: [id], onDelete: Cascade)
  concepto        String   // Semilla, Fertilizante, Fitosanitario, Labor, Maquinaria, Riego
  descripcion     String
  monto           Float
  fecha           DateTime
  laborId         String?
  labor           Labor?   @relation(fields: [laborId], references: [id], onDelete: SetNull)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([loteId])
  @@index([fecha])
}

model CostoAnimal {
  id              String   @id @default(cuid())
  animalId        String
  animal          Animal   @relation(fields: [animalId], references: [id], onDelete: Cascade)
  concepto        String   // Alimentación, Sanidad, Reproducción, Compra, Otros
  descripcion     String
  monto           Float
  fecha           DateTime
  eventoSanitarioId String?
  eventoSanitario   EventoSanitario? @relation(fields: [eventoSanitarioId], references: [id], onDelete: SetNull)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([animalId])
  @@index([fecha])
}

model MargenBruto {
  id              String   @id @default(cuid())
  tipo            String   // Lote, Animal
  referenciaId    String   // ID del lote o animal
  referenciaNombre String  // Nombre para display
  periodo         String   // Ej: "2024-Q1", "2024-01"
  ingresos        Float    @default(0)
  costos          Float    @default(0)
  margen          Float    @default(0)
  margenPorcentaje Float   @default(0)
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([tipo])
  @@index([referenciaId])
  @@index([periodo])
  @@unique([userId, tipo, referenciaId, periodo])  // ← AGREGÁ ESTA LÍNEA
}

model Arrendamiento {
  id                String   @id @default(cuid())
  loteId            String
  lote              Lote     @relation(fields: [loteId], references: [id], onDelete: Cascade)
  arrendatario      String   // Nombre del dueño de la tierra
  tipoContrato      String   // PagoFijo, QuintalesFijos, PorcentajeProduccion
  moneda            String   @default("USD")
  montoFijo         Float?   // Para PagoFijo (USD/UYU)
  quintales         Float?   // Para QuintalesFijos
  porcentaje        Float?   // Para PorcentajeProduccion (ej: 25%)
  fechaInicio       DateTime
  fechaFin          DateTime
  activo            Boolean  @default(true)
  observaciones     String?
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@index([userId])
  @@index([loteId])
  @@index([activo])
}