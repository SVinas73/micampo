  @@index([operador])
  @@index([maquinariaId])
  @@index([fecha])
  @@index([scoreGeneral])
  @@index([userId]) // ⬅️ AGREGAR ÍNDICE
}

// ============================================
// 9. OPERADORES (REGISTRO)
