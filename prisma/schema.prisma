// ============================================
// 8. EVALUACIÓN DE OPERADORES
// ============================================

model EvaluacionOperador {
  id           String     @id @default(cuid())
  operador     String // Nombre del operador
  maquinariaId String
  maquinaria   Maquinaria @relation(fields: [maquinariaId], references: [id], onDelete: Cascade)

  fecha           DateTime @default(now())
  duracionJornada Float // Horas

  // Métricas de seguridad (telemetría)
  velocidadPromedio    Float @default(0)
  velocidadMaxima      Float @default(0)
  frenadosBruscos      Int   @default(0)
  aceleracionesBruscas Int   @default(0)
  girosBruscos         Int   @default(0)
  excesosVelocidad     Int   @default(0)

  // Métricas de eficiencia
  tiempoTrabajando   Float @default(0) // Horas productivas
  tiempoRalenti      Float @default(0) // Horas en ralentí
  consumoCombustible Float @default(0) // Litros
  consumoPorHora     Float @default(0)

  // Métricas de cuidado
  usoAdecuado         Boolean @default(true)
  mantenimientoDiario Boolean @default(true)
  reporteProblemas    Boolean @default(true)

  // Scores calculados (0-100)
