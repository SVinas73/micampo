  cantidad       Float
  precioUnitario Float
  subtotal       Float
  iva            Float  @default(0)
  total          Float

  // Categorización
  categoria String? // Semilla, Fertilizante, Combustible, etc

  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([comprobanteId])
}

