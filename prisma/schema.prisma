}

model AjusteNutricional {
  id              String   @id @default(cuid())
  planNutricionalId String
  planNutricional   PlanNutricional @relation(fields: [planNutricionalId], references: [id], onDelete: Cascade)
  
  fecha           DateTime @default(now())
  motivo          String   // Peso, Producción, Salud, IA
  ajusteRealizado String
  datosAnteriores String?  // JSON
  datosNuevos     String   // JSON
  
  responsable     String?
  generadoPorIA   Boolean  @default(false)
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([planNutricionalId])
  @@index([fecha])
}

model AnalisisReproductivo {
  id              String   @id @default(cuid())
  
  tipoAnalisis    String   // Rodeo, Individual, Periodo
  fechaInicio     DateTime
  fechaFin        DateTime
  
  // Métricas generales
  totalHembras    Int
  hembrasCubiertas Int
  tasaServicio    Float    // %
  tasaPreniez     Float    // %
  tasaNatalidad   Float    // %
  tasaMortalidad  Float    // %
  
  // Eficiencia reproductiva
  intervaloPartos Float?   // días promedio
  edadPrimerParto Float?   // meses promedio
  criasDestetadas Int?
  pesoDestete     Float?   // kg promedio
  
  // Análisis por toro (si aplica)
  torosUtilizados Int?
  mejorToroId     String?  // ID del mejor toro
  
  // Costos
  costoTotal      Float?   // USD
  costoServicio   Float?   // USD por servicio
  costoCria       Float?   // USD por cría nacida
  
  // Recomendaciones IA
  recomendacionIA String?
  areasDeRecomen  String?  // JSON con áreas específicas
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([fechaInicio])
}

model AlertaSanitaria {
  id              String   @id @default(cuid())
  
  tipo            String   // Enfermedad, Vacunación, Tratamiento, Emergencia
  severidad       String   // Baja, Media, Alta, Crítica
  titulo          String
  descripcion     String
  
  // Alcance
  animalId        String?  // Si es individual
  categoria       String?  // Si es por categoría (todos los terneros, etc)
  numeroAfectados Int      @default(1)
  
  // Acción requerida
  accionRequerida String
  fechaLimite     DateTime?
  estado          String   @default("Pendiente") // Pendiente, EnProceso, Completada
  
  // IA
  deteccionIA     Boolean  @default(false)
  confianza       Float?   // 0-100
  recomendacion   String?
  
  // Resolución
  fechaResolucion DateTime?
  accionTomada    String?
  responsable     String?
  
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([userId])
  @@index([estado])
  @@index([severidad])
  @@index([tipo])
}